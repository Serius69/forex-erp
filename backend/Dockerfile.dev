# backend/Dockerfile.dev
# NOTA (2026-07-07): ningún docker-compose referencia este archivo — el dev real
# usa backend/Dockerfile con bind mount (./backend:/app). Se mantiene como
# variante ligera opcional; antes instalaba deps de MySQL (residuo de otro
# proyecto): este stack usa PostgreSQL (psycopg2-binary).
FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libpq-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# No copiamos el código — se monta como volumen en dev
EXPOSE 8007

CMD ["python", "manage.py", "runserver", "0.0.0.0:8007"]
