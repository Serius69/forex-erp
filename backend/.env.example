# ─── Django Core ──────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ─── Database ─────────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=forex_erp_dev
DB_USER=postgres
DB_PASSWORD=
# En Docker usa 'pgbouncer'. En dev local usa 'localhost' o 'db'
DB_HOST=pgbouncer
DB_PORT=5432
CONN_MAX_AGE=0

# ─── Redis (solo caché y channel layer) ──────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CHANNEL_REDIS_URL=redis://localhost:6379/2

# ─── RabbitMQ (broker de Celery) ─────────────────────────
RABBITMQ_URL=amqp://kapitalya:kapitalya_mq_pass@localhost:5672/kapitalya
RABBITMQ_USER=kapitalya
RABBITMQ_PASS=kapitalya_mq_pass
RABBITMQ_VHOST=kapitalya

# ─── CORS / Frontend ──────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── External APIs ────────────────────────────────────────
EXCHANGE_RATE_API_KEY=
FIXER_API_KEY=

# ─── Google OAuth ─────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
