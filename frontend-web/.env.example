# ── Desarrollo local ──────────────────────────────────────────────────────────
# Copia este archivo como .env.local y ajusta según tu entorno
# Vite solo expone variables con prefijo VITE_

# URL base de la API (vacío = proxy Vite en dev / nginx proxy en producción)
VITE_API_BASE_URL=/api

# URL base de WebSockets
VITE_WS_BASE_URL=/ws

# ── Tailscale — acceso desde otros dispositivos ───────────────────────────────
# VITE_API_BASE_URL=http://100.x.x.x:8000/api
# VITE_WS_BASE_URL=ws://100.x.x.x:8000/ws
